{
    "name": "allopneus/pneutracker",
    "description": "Application de gestion de rendez-vous pour centres de montage pneus",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": "^7.2",
        "symfony/routing": "^7.2",
        "doctrine/orm": "^3.3",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/doctrine-fixtures-bundle": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "symfony/test-pack": "^1.1",
        "symfony/browser-kit": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
